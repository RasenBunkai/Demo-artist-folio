---
import Layout from "./Layout.astro";
const { title, description, eyebrow = "Información" } = Astro.props;
---
<Layout title={title} description={description}>

  <main
    class="min-h-screen bg-gradient-to-b from-purple-200 via-pink-200 to-sky-200 px-4 py-32 dark:from-slate-900 dark:via-purple-900 dark:to-black/90"
  >
    <article
      class="mx-auto max-w-4xl rounded-3xl border border-purple-200/70 bg-white/75 p-6 shadow-xl shadow-purple-200/40 backdrop-blur-xl dark:border-purple-700/60 dark:bg-slate-950/75 dark:shadow-black/30 sm:p-10"
    >
      <header
        class="mb-10 border-b border-purple-200 pb-8 dark:border-purple-800"
      >
        <p
          class="mb-3 text-sm font-semibold uppercase tracking-[0.25em] text-purple-600 dark:text-purple-300"
        >
          {eyebrow}
        </p>
        <h3
          class="text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white md:text-5xl"
        >
          {title}
        </h3>

        <p
          class="mt-4 max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-slate-300"
        >
          {description}
        </p>
      </header>
        <slot />
    </article>
  </main>
</Layout>
