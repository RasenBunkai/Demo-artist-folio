---
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import {
  NativeSelect,
  NativeSelectOption,
} from "@/components/ui/native-select";
import { Textarea } from "@/components/ui/textarea";
import { MessageCircle, Send } from "lucide-react";
---

<Card
  className="border-purple-200 bg-white/70 shadow-sm backdrop-blur-sm transition-shadow duration-300 hover:shadow-md dark:border-purple-700 dark:bg-gray-800/70"
>
  <CardHeader className="border-b border-purple-100 dark:border-purple-900">
    <CardTitle
      className="flex items-center gap-3 text-2xl font-bold text-gray-800 dark:text-gray-200"
    >
      <MessageCircle className="size-6 text-purple-600 dark:text-purple-400" />
      Formulario de Contacto
    </CardTitle>
  </CardHeader>
  <CardContent className="p-6">
    <form class="space-y-6" name="contact" method="POST" data-netlify="true">
      <div class="grid md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <Label htmlFor="name" className="text-gray-700 dark:text-gray-300">
            Nombre *
          </Label>
          <Input
            id="name"
            name="name"
            type="text"
            required
            className="h-10 border-purple-200 bg-white dark:border-purple-700 dark:bg-slate-900"
            placeholder="Tu nombre completo"
          />
        </div>

        <div class="space-y-2">
          <Label htmlFor="email" className="text-gray-700 dark:text-gray-300">
            Email *
          </Label>
          <Input
            id="email"
            name="email"
            type="email"
            required
            className="h-10 border-purple-200 bg-white dark:border-purple-700 dark:bg-slate-900"
            placeholder="tu@email.com"
          />
        </div>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <Label
            htmlFor="commission"
            className="text-gray-700 dark:text-gray-300"
          >
            Tipo de Comisión *
          </Label>
          <NativeSelect
            id="commission"
            name="commission"
            required
            defaultValue=""
            className="w-full [&_select]:h-10 [&_select]:border-purple-200 [&_select]:bg-white dark:[&_select]:border-purple-700 dark:[&_select]:bg-slate-900"
          >
            <NativeSelectOption value="" disabled>
              Selecciona una opción
            </NativeSelectOption>
            <NativeSelectOption value="Busto">Busto ($50)</NativeSelectOption>
            <NativeSelectOption value="Medio Cuerpo">
              Medio Cuerpo ($85)
            </NativeSelectOption>
            <NativeSelectOption value="Cuerpo Completo">
              Cuerpo Completo ($120)
            </NativeSelectOption>
            <NativeSelectOption value="Otro">Otro</NativeSelectOption>
          </NativeSelect>
        </div>
        <div class="space-y-2">
          <Label htmlFor="budget" className="text-gray-700 dark:text-gray-300">
            Presupuesto
          </Label>
          <Input
            id="budget"
            name="budget"
            type="text"
            className="h-10 border-purple-200 bg-white dark:border-purple-700 dark:bg-slate-900"
            placeholder="Ej: $50-100"
          />
        </div>
      </div>
      <div class="space-y-2">
        <Label htmlFor="deadline" className="text-gray-700 dark:text-gray-300">
          Fecha Límite Deseada
        </Label>
        <Input
          id="deadline"
          name="deadline"
          type="date"
          className="h-10 border-purple-200 bg-white dark:border-purple-700 dark:bg-slate-900"
        />
      </div>
      <div class="space-y-2">
        <Label
          htmlFor="description"
          className="text-gray-700 dark:text-gray-300"
        >
          Descripción del Proyecto *
        </Label>
        <Textarea
          id="description"
          name="description"
          required
          rows={40}
          className="min-h-64 max-h-64 border-purple-200 bg-white dark:border-purple-700 dark:bg-slate-900"
          placeholder="Describe tu idea, incluye referencias, estilo deseado, colores, etc. Mientras más detalles, mejor será el resultado."
        />
      </div>
      <Button
        type="submit"
        size="lg"
        className="h-11 w-full rounded-full bg-gradient-to-r from-purple-600 to-pink-600 text-white shadow-md hover:from-purple-700 hover:to-pink-700 hover:shadow-lg"
      >
        <Send className="size-4" />
        Enviar Solicitud
      </Button>
    </form>
  </CardContent>
</Card>
