---
import { Badge } from "@/components/ui/badge";
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { Separator } from "@/components/ui/separator";
import {
  Banknote,
  CreditCard,
  Landmark,
  ShieldCheck,
  Wallet,
} from "lucide-react";

const methods = [
  {
    name: "PayPal",
    detail: "Internacional",
    icon: Wallet,
    accent: "from-blue-500 to-cyan-500",
  },
  {
    name: "Transferencia",
    detail: "Bancaria local",
    icon: Landmark,
    accent: "from-emerald-500 to-teal-500",
  },
];
---

<section
  id="payments"
  class="py-16 px-4 bg-gradient-to-b from-purple-200 via-pink-200 to-sky-200 dark:from-slate-900 dark:via-purple-900 dark:to-black/90"
>
  <div class="container mx-auto max-w-6xl">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <Badge
          variant="outline"
          className="mb-4 border-purple-300 bg-white/40 text-purple-700 backdrop-blur dark:border-purple-600 dark:bg-white/5 dark:text-purple-200"
        >
          <ShieldCheck className="size-3" />
          Pagos
        </Badge>
        <h2
          class="text-4xl md:text-5xl font-extrabold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent mb-3 leading-tight"
        >
          Métodos de pago
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          Para reservar tu comisión se solicita 50% de anticipo. El 50% restante
          se cubre antes de entregar los archivos finales en alta resolución.
        </p>
      </div>

      <Card
        className="border-purple-200 bg-white/75 shadow-lg backdrop-blur-sm dark:border-purple-700 dark:bg-gray-800/70"
      >
        <CardHeader>
          <CardTitle className="text-2xl text-gray-800 dark:text-gray-200">
            Opciones disponibles
          </CardTitle>
          <CardDescription className="text-gray-600 dark:text-gray-400">
            El método final se confirma durante la cotización.
          </CardDescription>
        </CardHeader>
        <CardContent>
          <div class="grid gap-4 sm:grid-cols-2">
            {
              methods.map((method) => {
                const Icon = method.icon;
                return (
                  <div class="rounded-xl border border-purple-100 bg-white/65 p-4 shadow-sm dark:border-purple-500/20 dark:bg-white/5">
                    <div
                      class={`mb-4 flex size-11 items-center justify-center rounded-lg bg-gradient-to-r ${method.accent} text-white shadow-sm`}
                    >
                      <Icon className="size-5" />
                    </div>
                    <h3 class="font-semibold text-gray-800 dark:text-gray-200">
                      {method.name}
                    </h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                      {method.detail}
                    </p>
                  </div>
                );
              })
            }
          </div>
          <Separator className="my-6 bg-purple-200 dark:bg-purple-800" />
          <div
            class="flex items-start gap-3 text-sm text-gray-600 dark:text-gray-300"
          >
            <ShieldCheck
              className="mt-0.5 size-5 flex-shrink-0 text-purple-600 dark:text-purple-300"
            />
            <p>
              Los pagos no incluyen cargos externos de plataforma. Si el
              proyecto requiere uso comercial, se cotiza como licencia
              adicional.
            </p>
          </div>
        </CardContent>
      </Card>
    </div>
  </div>
</section>
