---
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { Separator } from "@/components/ui/separator";
import { Landmark, ShieldCheck } from "lucide-react";
import Paypal from "./svg/Paypal.astro";

const methods = [
  {
    name: "PayPal",
    detail: "Internacional",
    icon: Paypal,
    accent: "from-blue-500 to-cyan-500",
  },
  {
    name: "Transferencia",
    detail: "Bancaria local",
    icon: Landmark,
    accent: "from-emerald-500 to-teal-500",
  },
];
---

<section
  id="payments"
  class="py-16 px-4 bg-gradient-to-b from-purple-200 via-pink-200 to-sky-200 dark:from-slate-900 dark:via-purple-900 dark:to-black/90"
>
  <div class="container mx-auto max-w-6xl">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div class="max-w-lg">
        <h2
          class="text-4xl md:text-5xl font-extrabold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent mb-3 leading-tight"
        >
          Métodos de pago
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          Para reservar tu comisión se solicita 50% de anticipo. El 50% restante
          se cubre antes de entregar los archivos finales en alta resolución.
        </p>
      </div>

      <Card
        className="border-purple-200 bg-white/75 shadow-lg backdrop-blur-sm dark:border-purple-700 dark:bg-gray-800/70"
      >
        <CardHeader>
          <CardTitle className="text-2xl text-gray-800 dark:text-gray-200">
            Opciones disponibles
          </CardTitle>
          <CardDescription className="text-gray-600 dark:text-gray-400">
            El método final se confirma durante la cotización.
          </CardDescription>
        </CardHeader>
        <CardContent>
          <div class="grid gap-5 sm:grid-cols-2">
            {
              methods.map((method, index) => {
                const Icon = method.icon;

                return (
                  <div class="group relative overflow-hidden rounded-2xl border border-purple-200/70 bg-white/75 p-5 shadow-sm backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:border-purple-300 hover:bg-white/90 hover:shadow-xl dark:border-purple-700/60 dark:bg-slate-900/70 dark:hover:border-purple-500 dark:hover:bg-slate-900/90">
                    {/* Ícono grande estilo frame/documento */}
                    <div class="pointer-events-none absolute -right-4 -top-5 text-slate-950/10 transition-all duration-300 group-hover:-rotate-3 group-hover:scale-105 dark:text-white/10">
                      <Icon className="size-32 stroke-[1.5]" />
                    </div>

                    <div class="relative z-10 flex min-h-40 flex-col justify-between">
                      <div>
                        <div class="mb-6 flex size-12 items-center justify-center rounded-full border border-purple-200 bg-purple-50 text-purple-700 shadow-sm dark:border-purple-500/30 dark:bg-purple-500/10 dark:text-purple-300">
                          {/* Número decorativo */}
                          <span class="text-sm font-semibold italic text-slate-400 dark:text-slate-500">
                            0{index + 1}
                          </span>
                        </div>

                        <h3 class="text-xl font-bold tracking-tight text-slate-900 dark:text-white">
                          {method.name}
                        </h3>

                        <p class="mt-2 max-w-[14rem] text-sm leading-relaxed text-slate-600 dark:text-slate-400">
                          {method.detail}
                        </p>
                      </div>

                      <div class="mt-6 h-px w-full bg-gradient-to-r from-purple-300/80 via-pink-300/60 to-transparent dark:from-purple-500/50 dark:via-pink-500/40" />

                      <p class="mt-3 text-xs font-medium uppercase tracking-[0.2em] text-purple-600 dark:text-purple-300">
                        Método disponible
                      </p>
                    </div>
                  </div>
                );
              })
            }
          </div>
          <Separator className="my-6 bg-purple-200 dark:bg-purple-800" />
          <div
            class="flex items-start gap-3 text-sm text-gray-600 dark:text-gray-300"
          >
            <ShieldCheck
              className="mt-0.5 size-5 flex-shrink-0 text-purple-600 dark:text-purple-300"
            />
            <p>
              Los pagos no incluyen cargos externos de plataforma. Si el
              proyecto requiere uso comercial, se cotiza como licencia
              adicional.
            </p>
          </div>
        </CardContent>
      </Card>
    </div>
  </div>
</section>
