---
import { Card, CardContent } from "@/components/ui/card";
import PricingCard from "./PricingCard.astro";
import { Flame, Sparkles, Zap } from "lucide-react";
import { Check } from "lucide-react";

const pricingPlans = [
  {
    name: "Busto",
    price: "$50",
    icon: Sparkles,
    description: "Retrato desde el pecho hacia arriba",
    features: [
      "Alta resolución (300 DPI)",
      "Fondo simple incluido",
      "2 revisiones incluidas",
      "Entrega en 5-7 días",
      "Formato PNG y JPG",
    ],
    popular: false,
    gradient: "from-blue-500 to-purple-500",
  },
  {
    name: "Medio Cuerpo",
    price: "$85",
    icon: Flame,
    description: "Desde la cintura hacia arriba",
    features: [
      "Alta resolución (300 DPI)",
      "Fondo detallado",
      "3 revisiones incluidas",
      "Entrega en 7-10 días",
      "Múltiples formatos",
      "Versión sin fondo",
    ],
    popular: true,
    gradient: "from-purple-500 to-pink-500",
  },
  {
    name: "Cuerpo Completo",
    price: "$120",
    icon: Zap,
    description: "Personaje completo con escenario",
    features: [
      "Ultra alta resolución",
      "Escenario personalizado",
      "Revisiones ilimitadas",
      "Entrega en 10-14 días",
      "Todos los formatos",
      "Proceso de trabajo incluido",
      "Derechos comerciales",
    ],
    popular: false,
    gradient: "from-pink-500 to-red-500",
  },
];

const IncludedFeatures = [
  "Archivo final en alta resolución",
  "Fondo simple o detallado según el plan",
  "Revisiones según el paquete",
  "Entrega en formatos PNG y JPG",
  "Comunicación durante el proceso",
  "Uso personal incluido",
  "Licencia comercial opcional",
];
---

<section
  id="pricing"
  class="py-16 px-4 bg-gradient-to-b from-purple-200 via-pink-200 to-sky-200 dark:from-slate-900 dark:via-purple-900 dark:to-black/90"
>
  <div class="container mx-auto max-w-6xl">
    <div class="text-center mb-14">
      <h2
        class="text-4xl md:text-5xl font-extrabold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent mb-3"
      >
        Precios de Comisiones
      </h2>
      <p
        class="text-lg md:text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto"
      >
        Planes transparentes y justos para cada tipo de proyecto.
      </p>
    </div>
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {pricingPlans.map((plan) => <PricingCard plan={plan} key={plan.name} />)}
    </div>
  </div>
  <Card
    className="container mx-auto max-w-4xl mt-14 border-purple-200 bg-gradient-to-r from-purple-100 to-pink-100 text-center shadow-lg dark:border-purple-700 dark:from-purple-900/40 dark:to-pink-900/40"
  >
    <CardContent className="p-6">
      <h4
        class="text-gray-800 dark:text-gray-200 mb-2 text-lg md:text-xl font-semibold"
      >
        ¿Qué incluye tu comisión?
      </h4>
      <div class="grid gap-3 sm:grid-cols-2">
        {
          IncludedFeatures.map((item) => (
            <div class="flex items-start gap-3 rounded-lg border border-emerald-100 bg-emerald-50/60 p-3 text-sm font-medium text-gray-700 dark:border-emerald-400/20 dark:bg-emerald-500/10 dark:text-gray-200">
              <Check className="mt-0.5 size-4 flex-shrink-0 text-emerald-600 dark:text-emerald-300" />
              <span>{item}</span>
            </div>
          ))
        }
      </div>
    </CardContent>
  </Card>
</section>
