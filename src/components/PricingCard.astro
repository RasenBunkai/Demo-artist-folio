---
import { Badge } from "@/components/ui/badge";
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { CheckCircle2 } from "lucide-react";

const { plan } = Astro.props;
const Icon = plan.icon;
import Image from "astro/components/Image.astro";
---

<Card
  className={`relative h-full overflow-hidden border-2 bg-white/70 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl dark:bg-gray-800/70 ${
    plan.popular
      ? "border-purple-400 shadow-purple-200 dark:border-purple-500 dark:shadow-purple-900/30"
      : "border-purple-200 hover:border-purple-300 dark:border-purple-700 dark:hover:border-purple-600"
  }`}
>
  {/* Badge "Más Popular" */}
  {
    plan.popular && (
      <div class="absolute left-0 right-0 top-0 flex justify-center">
        <Badge className="rounded-t-none rounded-b-xl bg-gradient-to-r from-purple-500 to-pink-500 px-4 py-1 text-sm font-semibold text-white shadow-sm">
          Más Popular
        </Badge>
      </div>
    )
  }

  <CardHeader
    className={`items-center text-center ${plan.popular ? "pt-12" : "pt-6"}`}
  >
    <CardTitle className="text-2xl font-bold text-gray-800 dark:text-gray-200 mb-2">
      {plan.name}
    </CardTitle>
    <div class="mx-auto mb-2 flex items-center justify-center">
      <Image
        class="w-full max-h-2/4 rounded-lg object-cover"
        src="/placeholder.svg?height=600&width=500"
        alt={`${plan.name} icon`}
        width={32}
        height={32}
      />
    </div>
    <CardDescription
      className="mt-2 text-base font-medium text-gray-600 dark:text-gray-300"
    >
      <p
        class="mt-2 text-4xl font-bold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent"
      >
        {plan.price}
      </p>
      {plan.description}
    </CardDescription>
  </CardHeader>

  <CardContent className="flex-1 px-6 pb-4">
    <ul class="mt-4 space-y-3">
      {
        plan.features.map((feature: string, idx: number) => (
          <li class="flex items-start gap-3">
            <CheckCircle2 className="mt-0.5 size-5 flex-shrink-0 text-purple-600 dark:text-purple-400" />
            <span class="text-md font-medium text-gray-700 dark:text-gray-300">
              {feature}
            </span>
          </li>
        ))
      }
    </ul>
  </CardContent>

  <CardFooter className="px-6 pb-6 pt-2">
    <a
      href="#contact"
      class={`flex items-center justify-center gap-2 w-full px-4 py-2 rounded-full text-lg font-semibold ${
        plan.popular
          ? "bg-gradient-to-r from-purple-600 to-pink-600 text-white shadow-md hover:from-purple-700 hover:to-pink-700 hover:shadow-lg"
          : "border-2 border-purple-600 bg-transparent text-purple-600 hover:bg-purple-50 dark:border-purple-400 dark:text-purple-300 dark:hover:bg-purple-950/30"
      }`}
      >Solicitar Comisión
    </a>
  </CardFooter>
</Card>
