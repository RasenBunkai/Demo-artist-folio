---
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { CheckCircle2, CircleSlash, ClipboardCheck } from "lucide-react";

const accepted = [
  "Retratos estilizados",
  "Personajes originales",
  "Fanart no comercial",
  "Parejas y grupos pequeños",
  "Fondos simples o mágicos",
  "Ilustraciones para redes",
];

const declined = [
  "Contenido ofensivo o de odio",
  "Imitación exacta de otro artista",
  "NFT o criptoarte",
  "Trabajos urgentes sin anticipo",
  "Realismo fotográfico extremo",
  "Uso comercial sin acuerdo previo",
];
---

<section
  id="guidelines"
  class="py-16 px-4 bg-gradient-to-t from-purple-200 via-pink-200 to-sky-200 dark:from-slate-900 dark:via-purple-900 dark:to-black/90">
  <div class="container mx-auto max-w-6xl">
    <div class="text-center mb-12">
      <h2
        class="text-4xl md:text-5xl font-extrabold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent mb-3 leading-tight">
        Qué sí hago / Qué no hago
      </h2>
      <p
        class="text-lg md:text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
        Antes de solicitar una comisión, revisa qué tipos de proyecto acepto y
        cuáles prefiero evitar.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-2">
      <Card
        className="border-emerald-200 bg-white/75 shadow-sm backdrop-blur-sm dark:border-emerald-500/30 dark:bg-gray-800/70">
        <CardHeader>
          <CardTitle className="flex items-center gap-3 text-2xl text-gray-800 dark:text-gray-200">
            <span
              class="flex size-10 items-center justify-center rounded-full bg-emerald-100 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-300">
              <CheckCircle2 className="size-5" />
            </span>
            Qué sí hago
          </CardTitle>
          <CardDescription className="text-gray-600 dark:text-gray-400">
            Proyectos donde puedo aportar mejor estilo, detalle y dirección.
          </CardDescription>
        </CardHeader>
        <CardContent>
          <div class="grid gap-3 sm:grid-cols-2">
            {
              accepted.map((item) => (
                <div class="flex items-start gap-3 rounded-lg border border-emerald-100 bg-emerald-50/60 p-3 text-sm font-medium text-gray-700 dark:border-emerald-400/20 dark:bg-emerald-500/10 dark:text-gray-200">
                  <CheckCircle2 className="mt-0.5 size-4 flex-shrink-0 text-emerald-600 dark:text-emerald-300" />
                  <span>{item}</span>
                </div>
              ))
            }
          </div>
        </CardContent>
      </Card>

      <Card
        className="border-rose-200 bg-white/75 shadow-sm backdrop-blur-sm dark:border-rose-500/30 dark:bg-gray-800/70">
        <CardHeader>
          <CardTitle className="flex items-center gap-3 text-2xl text-gray-800 dark:text-gray-200">
            <span
              class="flex size-10 items-center justify-center rounded-full bg-rose-100 text-rose-700 dark:bg-rose-500/15 dark:text-rose-300">
              <CircleSlash className="size-5" />
            </span>
            Qué no hago
          </CardTitle>
          <CardDescription className="text-gray-600 dark:text-gray-400">
            Casos que no acepto para mantener un proceso claro y sostenible.
          </CardDescription>
        </CardHeader>
        <CardContent>
          <div class="grid gap-3 sm:grid-cols-2">
            {
              declined.map((item) => (
                <div class="flex items-start gap-3 rounded-lg border border-rose-100 bg-rose-50/60 p-3 text-sm font-medium text-gray-700 dark:border-rose-400/20 dark:bg-rose-500/10 dark:text-gray-200">
                  <CircleSlash className="mt-0.5 size-4 flex-shrink-0 text-rose-600 dark:text-rose-300" />
                  <span>{item}</span>
                </div>
              ))
            }
          </div>
        </CardContent>
      </Card>
    </div>
  </div>
</section>
