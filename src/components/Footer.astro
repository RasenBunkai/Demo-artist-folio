---
import { Button } from "@/components/ui/button";
import { Separator } from "@/components/ui/separator";
import { ArrowUpRight,Palette } from "lucide-react";
import Tiktok from "./svg/Tiktok.astro";
import Youtube from "./svg/Youtube.astro";
import Twitter from "./svg/Twitter.astro";
import Instagram from "./svg/Instagram.astro";

const links = [
  { label: "Portafolio", href: "#portfolio" },
  { label: "Precios", href: "#pricing" },
  { label: "Lineamientos", href: "#guidelines" },
  { label: "Pagos", href: "#payments" },
  { label: "Proceso", href: "#process" },
  { label: "Contacto", href: "#contact" },
];

const services = [
  "Retratos Digitales",
  "Diseño de Personajes",
  "Ilustraciones",
  "Arte Conceptual",
  "Comisiones Personalizadas",
];
---

<footer
  class="text-white py-16 bg-gradient-to-b from-sky-200 via-pink-200 to-purple-200 dark:from-black/90 dark:via-slate-900/97 dark:to-gray-900">
  <div class="container mx-auto max-w-6xl px-4">
    <div class="grid md:grid-cols-4 gap-8">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <div
            class="w-10 h-10 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full flex items-center justify-center">
            <Palette className="size-6" />
          </div>
          <h3
            class="text-2xl font-bold bg-gradient-to-r from-purple-500 to-pink-500 bg-clip-text text-transparent dark:from-purple-400 dark:to-pink-400">
            Luna Artística
          </h3>
        </div>
        <p class="text-gray-600 dark:text-gray-400 mb-6 max-w-md">
          Creando arte digital único que da vida a tus ideas más creativas. Cada
          proyecto es una nueva aventura artística.
        </p>
        <div class="flex gap-3">
          <Button
            asChild
            variant="ghost"
            size="icon-lg"
            className="rounded-full text-gray-600 hover:text-purple-600 dark:text-gray-300 dark:hover:text-purple-300">
            <a href="https://www.instagram.com/" target="_blank" aria-label="Instagram">
              <Instagram className="size-5" />
            </a>
          </Button>
          <Button
            asChild
            variant="ghost"
            size="icon-lg"
            className="rounded-full text-gray-600 hover:text-purple-600 dark:text-gray-300 dark:hover:text-purple-300">
            <a href="https://x.com/home" target="_blank" aria-label="X">
              <Twitter className="size-5" />
            </a>
          </Button>
          <Button
            asChild
            variant="ghost"
            size="icon-lg"
            className="rounded-full text-gray-600 hover:text-purple-600 dark:text-gray-300 dark:hover:text-purple-300">
            <a href="https://www.youtube.com/" target="_blank" aria-label="YouTube">
              <Youtube className="size-5" />
            </a>
          </Button>
          <Button
            asChild
            variant="ghost"
            size="icon-lg"
            className="rounded-full text-gray-600 hover:text-purple-600 dark:text-gray-300 dark:hover:text-purple-300">
            <a href="https://www.tiktok.com/" target="_blank" aria-label="TikTok">
              <Tiktok className="size-5" />
            </a>
          </Button>
        </div>
      </div>
      <div>
        <h4 class="text-lg font-semibold mb-4 text-gray-600 dark:text-white">
          Enlaces Rápidos
        </h4>
        <ul class="space-y-2">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="group inline-flex items-center text-gray-600 transition-colors hover:text-purple-600 dark:text-gray-400 dark:hover:text-purple-400">
                  {link.label}
                  <ArrowUpRight className="ml-1 size-4 opacity-0 transition-all duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:opacity-100" />
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h4 class="text-lg font-semibold mb-4 text-gray-600 dark:text-white">
          Servicios
        </h4>
        <ul class="space-y-2">
          {
            services.map((service) => (
              <li>
                <span class="text-gray-600 dark:text-gray-400">{service}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
    <Separator className="my-8 bg-gray-300 dark:bg-gray-800" />
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex items-center gap-2 text-gray-600 dark:text-gray-400">
        <span>© 2024 Luna Artística. Hecho con mucha creatividad</span>
      </div>
      <div class="flex flex-wrap justify-center gap-6 text-sm">
        <a href="#" class="text-gray-600 dark:text-gray-400 hover:text-purple-600 dark:hover:text-purple-400 transition-colors">
          Términos de Servicio
        </a>
        <a href="#" class="text-gray-600 dark:text-gray-400 hover:text-purple-600 dark:hover:text-purple-400 transition-colors">
          Política de Privacidad
        </a>
        <a href="#" class="text-gray-600 dark:text-gray-400 hover:text-purple-600 dark:hover:text-purple-400 transition-colors">
          FAQ
        </a>
      </div>
    </div>
  </div>
</footer>
