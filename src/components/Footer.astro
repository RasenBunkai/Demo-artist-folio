---
import { Button } from "@/components/ui/button";
import { Separator } from "@/components/ui/separator";
import { Palette } from "lucide-react";
import Tiktok from "./svg/Tiktok.astro";
import Youtube from "./svg/Youtube.astro";
import Twitter from "./svg/Twitter.astro";
import Instagram from "./svg/Instagram.astro";
import FooterText from "./svg/Footertext.svg";

const services = [
  "Retratos Digitales",
  "Diseño de Personajes",
  "Ilustraciones",
  "Arte Conceptual",
  "Comisiones Personalizadas",
];
const socialMedia = [
  { label: "Twitter", href: "https://twitter.com/", icon: Twitter },
  { label: "Instagram", href: "https://instagram.com/", icon: Instagram },
  { label: "TikTok", href: "https://tiktok.com/", icon: Tiktok },
  { label: "YouTube", href: "https://youtube.com/", icon: Youtube },
];
const Entry = [
  { label: "Términos de Servicio", href: "#" },
  { label: "Política de Privacidad", href: "#" },
  { label: "FAQ", href: "#" },
];
---

<footer
  class="relative overflow-hidden text-white py-16 bg-gradient-to-b from-sky-200 via-pink-200 to-purple-200 dark:from-black/90 dark:via-slate-900/97 dark:to-gray-900"
>
  <img
    src={FooterText.src}
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 bottom-0 z-0 mx-auto w-[min(1200px,115vw)] max-w-none opacity-35 blur-sm dark:opacity-20"
  />
  <div class="container relative z-10 mx-auto max-w-6xl px-4">
    <div class="grid md:grid-cols-4 gap-8">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <div
            class="w-10 h-10 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full flex items-center justify-center"
          >
            <Palette className="size-6" />
          </div>
          <h3
            class="text-2xl font-bold bg-gradient-to-r from-purple-500 to-pink-500 bg-clip-text text-transparent dark:from-purple-400 dark:to-pink-400"
          >
            Luna Artística
          </h3>
        </div>
        <p class="text-gray-600 dark:text-gray-400 mb-6 max-w-md">
          Creando arte digital único que da vida a tus ideas más creativas. Cada
          proyecto es una nueva aventura artística.
        </p>
        <div class="flex gap-3">
          {
            socialMedia.map((social) => (
              <a
                href={social.href}
                class="size-10 rounded-full hover:scale-110 transition-transform"
                aria-label={`Visitar ${social.label}`}
              >
                <social.icon className="size-5" />
              </a>
            ))
          }
        </div>
      </div>
      <div class="md:col-span-1 md:col-start-4 md:justify-self-end">
        <h4 class="text-lg font-semibold mb-4 text-gray-600 dark:text-white">
          Servicios
        </h4>
        <ul class="space-y-2">
          {
            services.map((service) => (
              <li>
                <span class="text-gray-600 dark:text-gray-400">{service}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
    <Separator className="my-8 bg-gray-300 dark:bg-gray-800" />
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex items-center gap-2 text-gray-600 dark:text-gray-400">
        <span>© 2024 Luna Artística. Hecho con mucha creatividad</span>
      </div>
      <div class="flex flex-wrap justify-center gap-6 text-sm">
        {
          Entry.map((entry) => (
            <a
              href={entry.href}
              class="text-gray-600 dark:text-gray-400 hover:bg-purple-100 hover:text-purple-500 dark:hover:text-white dark:hover:bg-purple-500 transition-colors rounded-full px-3 py-1"
            >
              {entry.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
