---
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import Image from "astro/components/Image.astro";
import { ArrowUpRight, Palette, Sparkles } from "lucide-react";
import Tiktok from "./svg/Tiktok.astro";
import Youtube from "./svg/Youtube.astro";
import Twitter from "./svg/Twitter.astro";
import Instagram from "./svg/Instagram.astro";

const available = true;
const waitList = [{ date: new Date("2026-07-30") }];
const socialMedia = [
  { label: "Twitter", href: "https://twitter.com/", icon: Twitter },
  { label: "Instagram", href: "https://instagram.com/", icon: Instagram },
  { label: "TikTok", href: "https://tiktok.com/", icon: Tiktok },
];
---

<section
  id="home"
  class="relative min-h-screen flex items-center justify-center px-4 py-20 bg-gradient-to-b from-purple-200 via-pink-200 to-sky-200 dark:from-slate-900 dark:via-purple-900 dark:to-black/90"
>
  <div class="absolute inset-0 overflow-hidden">
    <div
      class="absolute top-1/4 left-1/4 w-64 h-64 bg-purple-300/70 rounded-full blur-3xl animate-pulse"
    >
    </div>
    <div
      class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-pink-300/70 rounded-full blur-3xl animate-pulse delay-1000"
    >
    </div>
  </div>
  <div class="container mx-auto max-w-6xl relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="text-center lg:text-left space-y-8">
        <div class="space-y-4">
          <div
            class="flex flex-wrap items-center justify-center lg:justify-start gap-2 text-purple-600 dark:text-purple-400"
          >
            <Palette className="size-5" />
            <span class="text-sm font-medium tracking-wide uppercase">
              Artista Digital
            </span>
            {
              available ? (
                <Badge className="bg-emerald-100 text-emerald-800 ring-1 ring-emerald-200 hover:bg-emerald-100 dark:bg-emerald-500/15 dark:text-emerald-200 dark:ring-emerald-400/30">
                  Abierto a comisiones
                </Badge>
              ) : (
                <Badge variant="destructive">
                  No disponible para comisiones
                </Badge>
              )
            }
          </div>
          <h1
            class="text-4xl md:text-6xl lg:text-7xl font-bold bg-gradient-to-r from-purple-600 via-pink-600 to-indigo-600 bg-clip-text text-transparent leading-tight"
          >
            Luna Artística
          </h1>
          <p
            class="text-xl md:text-2xl text-gray-600 max-w-2xl dark:text-white"
          >
            Creando mundos digitales únicos donde la imaginación cobra vida.
            <span class="block mt-2 text-lg italic">
              "Cada trazo cuenta una historia, cada color despierta emociones"
            </span>
          </p>
        </div>
        <div
          class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start"
        >
          <a
            href="#portfolio"
            class="flex items-center h-11 rounded-full bg-gradient-to-r from-purple-600 to-pink-600 px-8 text-white shadow-md hover:from-purple-700 hover:to-pink-700 hover:shadow-lg"
          >
            Ver Portafolio
            <ArrowUpRight
              className="ml-1 size-4 transition-transform duration-200 group-hover/button:rotate-45"
            />
          </a>
          <a
            href="#contact"
            class="flex items-center h-11 rounded-full border-2 border-purple-300 bg-white/40 px-8 text-purple-900 backdrop-blur hover:bg-purple-50 dark:border-purple-600 dark:bg-white/5 dark:text-white dark:hover:bg-purple-900/30"
          >
            Pedir Comisión
            <Sparkles
              className="ml-1 size-4 transition-transform duration-200 group-hover/button:rotate-12"
            />
          </a>
        </div>
        <div class="grid grid-cols-3 gap-4 pt-8 text-center lg:max-w-xl">
          <h4 class="col-span-3 text-sm font-semibold text-gray-800 dark:text-gray-200">
            Sígueme en redes sociales
          </h4>
          {
            socialMedia.map((social) => (
              <a
                href={social.href}
                target="_blank"
                class="flex flex-col items-center gap-2 rounded-lg border border-purple-200 bg-white/40 px-4 py-3 text-sm font-medium text-gray-700 hover:bg-purple-200 dark:border-purple-700/50 dark:bg-gray-800/70 dark:text-gray-300 dark:hover:bg-purple-900/40"
              >
                <social.icon className="size-5" />
                {social.label}
              </a>
            ))
            }
        </div>
      </div>
      <div class="relative">
        <div class="relative w-full max-w-lg mx-auto">
          <div
            class="absolute inset-0 bg-gradient-to-r from-purple-400 to-pink-400 rounded-3xl blur-2xl opacity-30 animate-pulse"
          >
          </div>
          <Image
            src="/placeholder.svg?height=600&width=500"
            alt="Artwork showcase"
            width={500}
            height={600}
            draggable="false"
            class="relative z-10 w-full max-h-[700px] rounded-3xl shadow-2xl overflow-hidden object-cover"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </div>
</section>
