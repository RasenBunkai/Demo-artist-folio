---
import { Button } from "@/components/ui/button";
import { Moon, Sun } from "lucide-react";
---

<Button
  id="themeToggle"
  type="button"
  variant="outline"
  size="icon-lg"
  aria-label="Cambiar tema"
  className="rounded-full border-purple-300 bg-white text-purple-900 shadow-lg backdrop-blur hover:bg-purple-50 dark:border-purple-600 dark:bg-white/10 dark:text-white dark:hover:bg-purple-900/30 hover:cursor-pointer"
>
  <Sun className="sun-icon size-5" />
  <Moon className="moon-icon absolute size-5" />
</Button>

<style>
  .moon-icon {
    opacity: 0;
    transform: scale(0.8);
  }

  .sun-icon,
  .moon-icon {
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  :global(.dark) .sun-icon {
    opacity: 0;
    transform: scale(0.8);
  }

  :global(.dark) .moon-icon {
    opacity: 1;
    transform: scale(1);
  }
</style>

<script is:inline>
  (function () {
    const theme = (() => {
      if (
        typeof localStorage !== "undefined" &&
        localStorage.getItem("theme")
      ) {
        return localStorage.getItem("theme");
      }
      if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
        return "dark";
      }
      return "light";
    })();
    document.documentElement.classList.remove("dark", "light");
    document.documentElement.classList.add(theme);
    window.localStorage.setItem("theme", theme);
  })();

  document.addEventListener("DOMContentLoaded", function () {
    document
      .getElementById("themeToggle")
      ?.addEventListener("click", function () {
        const element = document.documentElement;
        if (element.classList.contains("dark")) {
          element.classList.remove("dark");
          element.classList.add("light");
          localStorage.setItem("theme", "light");
        } else {
          element.classList.remove("light");
          element.classList.add("dark");
          localStorage.setItem("theme", "dark");
        }
      });
  });
</script>
